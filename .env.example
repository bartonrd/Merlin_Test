# Merlin – configuration reference
# Copy this file to .env and adjust values for your environment.
# All settings can also be overridden with environment variables.

# ── LLM mode ─────────────────────────────────────────────────────────────────
# Choose one of:
#   remote  (default) – connect to an external OpenAI-compatible HTTP server
#                       (llama.cpp server, Ollama, LM Studio, …)
#   local             – run a GGUF model file directly in-process
#                       via llama-cpp-python (no separate server needed)
#   none              – return retrieved document excerpts without any LLM
#                       synthesis (works immediately, no model required)
LLM_MODE=local

# ── Remote server settings (LLM_MODE=remote) ─────────────────────────────────
# URL of the OpenAI-compatible server
LLM_BASE_URL=http://localhost:8080
# Model name to pass to the server (ignored by llama.cpp, required by Ollama)
LLM_MODEL=local-model

# ── Local model settings (LLM_MODE=local) ────────────────────────────────────
# Absolute path to a GGUF model file.
# The llama-cpp-python backend is installed automatically by start.bat / start.sh.
# Change this path to point at any GGUF model on your machine.
LLM_MODEL_PATH=C:\dev\_models\mistral-7b-instruct-v0.1.Q5_K_S.gguf

# ── Generation parameters ─────────────────────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
LLM_CONTEXT_WINDOW=4096

# ── Embedding settings ────────────────────────────────────────────────────────
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DEVICE=cpu

# ── Retrieval settings ────────────────────────────────────────────────────────
TOP_K_BM25=10
TOP_K_VECTOR=10
TOP_K_FINAL=5
RERANKER_ENABLED=false
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Storage paths ─────────────────────────────────────────────────────────────
DB_PATH=./data/db.sqlite
FAISS_PATH=./data/index.faiss
FAISS_MAP_PATH=./data/faiss_map.pkl
DOCS_DIR=./docs
AUDIT_LOG_PATH=./data/audit.log

# ── Context limits ────────────────────────────────────────────────────────────
MAX_CONTEXT_CHARS=6000

# ── API access control ────────────────────────────────────────────────────────
# Set API_KEY to a secret string to require the `X-API-Key` header on all
# /chat and /v1/chat/completions requests.  Leave blank to allow open access.
# API_KEY=change-me-to-a-secret-value

# Comma-separated list of allowed CORS origins, or * to allow all origins.
# Use * for open/internal networks; list explicit origins in production.
CORS_ORIGINS=*
